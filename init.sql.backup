-- Initialize Aircraft Predictive Maintenance Database

-- Create extensions
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- Users table
CREATE TABLE users (
    id SERIAL PRIMARY KEY,
    username VARCHAR(64) UNIQUE NOT NULL,
    email VARCHAR(120) UNIQUE NOT NULL,
    password_hash VARCHAR(256) NOT NULL,
    role VARCHAR(20) DEFAULT 'user',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    is_active BOOLEAN DEFAULT TRUE
);

-- Flight surveys table
CREATE TABLE flight_surveys (
    id SERIAL PRIMARY KEY,
    user_id INTEGER REFERENCES users(id),
    aircraft_model VARCHAR(50) NOT NULL,
    flight_details JSONB NOT NULL,
    survey_data JSONB NOT NULL,
    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Prediction results table
CREATE TABLE prediction_results (
    id SERIAL PRIMARY KEY,
    survey_id INTEGER REFERENCES flight_surveys(id),
    user_id INTEGER REFERENCES users(id),
    
    -- Aircraft information
    model_type VARCHAR(50) NOT NULL,
    flight_number VARCHAR(20),
    registration_number VARCHAR(20),
    
    -- Prediction data
    survey_data JSONB NOT NULL,
    prediction_result JSONB NOT NULL,
    fault_detections JSONB NOT NULL,
    flight_condition VARCHAR(20) NOT NULL,
    confidence_score FLOAT DEFAULT 0.0,
    
    -- XAI explanations
    shap_explanations JSONB,
    lime_explanations JSONB,
    
    -- Contact information
    owner_email VARCHAR(120),
    management_email VARCHAR(120),
    maintenance_email VARCHAR(120),
    
    -- Timestamps
    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    email_sent BOOLEAN DEFAULT FALSE,
    email_sent_at TIMESTAMP
);

-- Aircraft configurations table
CREATE TABLE aircraft_configs (
    id SERIAL PRIMARY KEY,
    model_name VARCHAR(50) UNIQUE NOT NULL,
    config_data JSONB NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Maintenance logs table
CREATE TABLE maintenance_logs (
    id SERIAL PRIMARY KEY,
    aircraft_id VARCHAR(20) NOT NULL,
    prediction_id INTEGER REFERENCES prediction_results(id),
    maintenance_type VARCHAR(50) NOT NULL,
    description TEXT,
    performed_by VARCHAR(100),
    performed_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    next_due_date DATE
);

-- Create indexes for performance
CREATE INDEX idx_prediction_results_timestamp ON prediction_results(timestamp DESC);
CREATE INDEX idx_prediction_results_condition ON prediction_results(flight_condition);
CREATE INDEX idx_prediction_results_model ON prediction_results(model_type);
CREATE INDEX idx_flight_surveys_user ON flight_surveys(user_id);
CREATE INDEX idx_maintenance_logs_aircraft ON maintenance_logs(aircraft_id);

-- Create function to update updated_at timestamp
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = CURRENT_TIMESTAMP;
    RETURN NEW;
END;
$$ language 'plpgsql';

-- Create trigger for aircraft_configs
CREATE TRIGGER update_aircraft_configs_updated_at
    BEFORE UPDATE ON aircraft_configs
    FOR EACH ROW
    EXECUTE FUNCTION update_updated_at_column();

