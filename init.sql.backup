-- Create view for dashboard statistics
CREATE VIEW dashboard_stats AS
SELECT 
    COUNT(*) as total_predictions,
    COUNT(CASE WHEN flight_condition = 'normal' THEN 1 END) as safe_flights,
    COUNT(CASE WHEN flight_condition = 'warning' THEN 1 END) as warning_flights,
    COUNT(CASE WHEN flight_condition = 'critical' THEN 1 END) as critical_flights,
    AVG(confidence_score) as avg_confidence,
    MAX(timestamp) as last_prediction
FROM prediction_results;

-- Grant permissions (adjust as needed)
GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO postgres;
GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public TO postgres;