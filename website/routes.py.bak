@app.route('/process-prediction')
def process_prediction():
    """Process prediction with loading screen"""
    return render_template('processing.html')

@app.route('/api/predict', methods=['POST'])
def api_predict():
    """API endpoint for prediction processing"""
    try:
        # Get data from session
        flight_details = session.get('flight_details', {})
        survey_data = session.get('survey_data', {})
        model_name = session.get('selected_model', '')
        
        if not flight_details or not survey_data:
            return jsonify({'error': 'Missing data'}), 400
        
        # Process survey data for ML model
        processed_data = process_survey_data(survey_data, model_name)
        
        # Get ML model prediction
        # Use rule-based prediction (ML models are disabled for now)
        prediction, fault_results = predict_flight_safety(survey_data, model_name)
        # ml_model, classifier = app.load_ml_model()
        
        # if ml_model:
        #     # Prepare input for model (simplified for demonstration)
        #     vibration_data = np.random.randn(1, 1000, 1)
        #     thermal_data = np.random.randn(1, 500, 1)
        #     acoustic_data = np.random.randn(1, 250, 1)
        #     pressure_data = np.random.randn(1, 100, 1)
            
        #     # Make prediction
        #     prediction = ml_model.predict(
        #         vibration_data, thermal_data, acoustic_data, pressure_data
        #     )
            
        #     # Use classifier for fault detection
        #     fault_results = classifier.predict_with_confidence(
        #         ml_model.model,
        #         [vibration_data, thermal_data, acoustic_data, pressure_data],
        #         threshold=0.7
        #     )
        # else:
        #     # Fallback to rule-based prediction
        #     prediction, fault_results = predict_flight_safety(survey_data, model_name)
        
        # Determine flight condition
        condition = determine_flight_condition(prediction, fault_results)
        
        # Generate XAI explanations
        xai_explanations = generate_xai_explanations(processed_data, model_name)
        
        # Create prediction result
        prediction_result = PredictionResult(
            model_type=model_name,
            flight_number=flight_details.get('flight_number', 'N/A'),
            registration_number=flight_details.get('registration_number', 'N/A'),
            survey_data=json.dumps(survey_data),
            prediction_result=json.dumps(prediction),
            fault_detections=json.dumps(fault_results),
            flight_condition=condition,
            confidence_score=prediction.get('confidence', 0.85),
            owner_email=flight_details.get('owner_email'),
            management_email=flight_details.get('management_email'),
            maintenance_email=flight_details.get('maintenance_email')
        )
        
        db.session.add(prediction_result)
        db.session.commit()
        
        # Store result ID in session
        session['prediction_id'] = prediction_result.id
        
        # Send emails (async)
        send_emails_async(prediction_result, flight_details, condition)
        
        return jsonify({
            'success': True,
            'prediction_id': prediction_result.id,
            'condition': condition,
            'redirect_url': url_for('prediction_result', prediction_id=prediction_result.id)
        })
        
    except Exception as e:
        app.logger.error(f"Prediction error: {str(e)}")
        return jsonify({'error': str(e)}), 500

@app.route('/prediction-result/<int:prediction_id>')
def prediction_result(prediction_id):
    """Display prediction results"""
    prediction = PredictionResult.query.get_or_404(prediction_id)
    
    # Parse JSON data
    prediction_data = json.loads(prediction.prediction_result)
    fault_detections = json.loads(prediction.fault_detections)
    
    # Generate explanation text based on condition
    explanation = generate_explanation(prediction.flight_condition, fault_detections)
    
    return render_template('prediction.html',
                         prediction=prediction,
                         prediction_data=prediction_data,
                         fault_detections=fault_detections,
                         explanation=explanation)

@app.route('/email-preview/<int:prediction_id>')
def email_preview(prediction_id):
    """Preview email that was sent"""
    prediction = PredictionResult.query.get_or_404(prediction_id)
    return render_template('email_template.html', prediction=prediction)

# Helper functions
def determine_flight_condition(prediction, fault_results):
    """Determine flight condition based on prediction and faults"""
    total_faults = fault_results.get('total_faults', 0)
    critical_faults = fault_results.get('critical_faults', 0)
    confidence = prediction.get('confidence', 0)
    
    if critical_faults > 0 or confidence < 0.6:
        return 'critical'  # Flight is not working
    elif total_faults > 0 or confidence < 0.8:
        return 'warning'   # Working but has some failures
    else:
        return 'normal'    # Working good

