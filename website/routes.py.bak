def generate_explanation(condition, fault_detections):
    """Generate human-readable explanation"""
    explanations = {
        'normal': {
            'title': '✅ Flight is SAFE to fly',
            'description': 'All systems are operating within normal parameters. No critical faults detected.',
            'recommendation': 'Flight is approved for operation. Continue with regular maintenance schedule.',
            'color': 'success'
        },
        'warning': {
            'title': '⚠️ Flight has SOME ISSUES',
            'description': f"Detected {fault_detections.get('total_faults', 0)} potential issues. "
                          f"{fault_detections.get('critical_faults', 0)} require immediate attention.",
            'recommendation': 'Schedule maintenance before next flight. Some systems need inspection.',
            'color': 'warning'
        },
        'critical': {
            'title': '❌ Flight is NOT SAFE to fly',
            'description': f"Detected {fault_detections.get('total_faults', 0)} critical issues. "
                          f"Immediate maintenance required.",
            'recommendation': 'DO NOT FLY. Ground aircraft immediately and perform thorough inspection.',
            'color': 'danger'
        }
    }
    
    return explanations.get(condition, explanations['critical'])

def send_emails_async(prediction_result, flight_details, condition):
    """Send emails asynchronously"""
    thread = threading.Thread(
        target=send_prediction_email,
        args=(prediction_result, flight_details, condition)
    )
    thread.daemon = True
    thread.start()

@app.route('/login', methods=['GET', 'POST'])
def login():
    """User login"""
    if current_user.is_authenticated:
        return redirect(url_for('index'))
    
    form = LoginForm()
    if form.validate_on_submit():
        user = User.query.filter_by(email=form.email.data).first()
        if user and user.check_password(form.password.data):
            login_user(user, remember=form.remember.data)
            next_page = request.args.get('next')
            return redirect(next_page) if next_page else redirect(url_for('index'))
        else:
            flash('Login unsuccessful. Please check email and password', 'danger')
    
    return render_template('login.html', form=form)

@app.route('/register', methods=['GET', 'POST'])
def register():
    """User registration"""
    if current_user.is_authenticated:
        return redirect(url_for('index'))
    
    form = RegistrationForm()
    if form.validate_on_submit():
        user = User(
            username=form.username.data,
            email=form.email.data,
            role=form.role.data
        )
        user.set_password(form.password.data)
        db.session.add(user)
        db.session.commit()
        flash('Your account has been created! You can now log in', 'success')
        return redirect(url_for('login'))
    
    return render_template('register.html', form=form)

@app.route('/logout')
def logout():
    """User logout"""
    logout_user()
    return redirect(url_for('index'))

@app.route('/history')
@login_required
def history():
    """View prediction history"""
    predictions = PredictionResult.query.order_by(
        PredictionResult.timestamp.desc()
    ).limit(50).all()
    return render_template('history.html', predictions=predictions)