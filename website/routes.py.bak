@app.route('/')
def index():
    """Home page - Welcome and model selection"""
    return render_template('index.html', 
                         boeing_config=app.config.get('BOEING_CONFIG', {}),
                         cessna_config=app.config.get('CESSNA_CONFIG', {}),
                         airbus_config=app.config.get('AIRBUS_CONFIG', {}))

@app.route('/select-model/<model_name>')
def select_model(model_name):
    """Store selected model in session and redirect to flight details"""
    session['selected_model'] = model_name
    
    # Get model configuration
    if model_name == 'boeing_737':
        model_config = app.BOEING_CONFIG
    elif model_name == 'cessna_172':
        model_config = app.CESSNA_CONFIG
    elif model_name == 'airbus_h125':
        model_config = app.AIRBUS_CONFIG
    else:
        flash('Invalid aircraft model selected', 'danger')
        return redirect(url_for('index'))
    
    session['model_config'] = model_config
    return redirect(url_for('flight_details'))

@app.route('/flight-details', methods=['GET', 'POST'])
def flight_details():
    """Flight owner and management details form"""
    if 'selected_model' not in session:
        flash('Please select an aircraft model first', 'warning')
        return redirect(url_for('index'))
    
    form = FlightDetailsForm()
    
    if form.validate_on_submit():
        # Store flight details in session
        session['flight_details'] = {
            'owner_name': form.owner_name.data,
            'owner_email': form.owner_email.data,
            'pilot_name': form.pilot_name.data,
            'co_pilot_name': form.co_pilot_name.data,
            'management_team': form.management_team.data,
            'management_email': form.management_email.data,
            'maintenance_manager': form.maintenance_manager.data,
            'maintenance_email': form.maintenance_email.data,
            'flight_number': form.flight_number.data,
            'registration_number': form.registration_number.data,
            'total_flight_hours': form.total_flight_hours.data,
            'last_maintenance_date': form.last_maintenance_date.data.isoformat() if form.last_maintenance_date.data else None
        }
        
        # Redirect to survey based on selected model
        model_name = session['selected_model']
        if model_name == 'boeing_737':
            return redirect(url_for('boeing_survey'))
        elif model_name == 'cessna_172':
            return redirect(url_for('cessna_survey'))
        elif model_name == 'airbus_h125':
            return redirect(url_for('airbus_survey'))
    
    # Get model name for display
    model_name = session.get('selected_model', '').replace('_', ' ').title()
    return render_template('flight_details.html', form=form, model_name=model_name)

@app.route('/survey/boeing', methods=['GET', 'POST'])
def boeing_survey():
    """Boeing 737 survey questions"""
    if 'selected_model' not in session or session['selected_model'] != 'boeing_737':
        flash('Please select Boeing 737 model first', 'warning')
        return redirect(url_for('index'))
    
    if 'flight_details' not in session:
        flash('Please provide flight details first', 'warning')
        return redirect(url_for('flight_details'))
    
    form = BoeingSurveyForm()
    
    if form.validate_on_submit():
        # Process survey data
        survey_data = {
            'engine': {
                'n1_rpm': form.n1_rpm.data,
                'n2_rpm': form.n2_rpm.data,
                'egt': form.egt.data,
                'oil_temperature': form.oil_temperature.data,
                'oil_pressure': form.oil_pressure.data,
                'vibration_level': form.vibration_level.data
            },
            'structural': {
                'wing_vibration': form.wing_vibration.data,
                'fuselage_strain': form.fuselage_strain.data
            },
            'systems': {
                'hydraulic_pressure': form.hydraulic_pressure.data,
                'cabin_pressure_altitude': form.cabin_pressure_altitude.data,
                'bleed_air_temperature': form.bleed_air_temperature.data
            },
            'flight_controls': {
                'aileron_position': form.aileron_position.data,
                'elevator_position': form.elevator_position.data
            }
        }
        
        session['survey_data'] = survey_data
        return redirect(url_for('process_prediction'))
    
    return render_template('survey_boeing.html', form=form, config=app.BOEING_CONFIG)

