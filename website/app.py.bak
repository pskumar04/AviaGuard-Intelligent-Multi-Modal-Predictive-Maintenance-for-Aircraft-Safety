# app.config['MAIL_PASSWORD'] = os.environ.get('MAIL_PASSWORD')
# app.config['MAIL_DEFAULT_SENDER'] = os.environ.get('MAIL_DEFAULT_SENDER', 'noreply@aircraft-pm.com')

# Initialize extensions
db = SQLAlchemy(app)
# mail = Mail(app)  # COMMENT OUT if not using email
bootstrap = Bootstrap(app)
moment = Moment(app)
login_manager = LoginManager(app)
login_manager.login_view = 'login'
login_manager.login_message_category = 'info'

# Load aircraft configurations
try:
    with open('aircraft_configs/boeing_737_ng.json', 'r') as f:
        BOEING_CONFIG = json.load(f)
    with open('aircraft_configs/cessna_172.json', 'r') as f:
        CESSNA_CONFIG = json.load(f)
    with open('aircraft_configs/airbus_h125.json', 'r') as f:
        AIRBUS_CONFIG = json.load(f)
    print("✅ Aircraft configurations loaded")
except Exception as e:
    print(f"⚠️ Warning: Could not load config files: {e}")
    # Default configs
    BOEING_CONFIG = {"aircraft_model": "Boeing 737 NG", "type": "Commercial Jet"}
    CESSNA_CONFIG = {"aircraft_model": "Cessna 172", "type": "Light Aircraft"}
    AIRBUS_CONFIG = {"aircraft_model": "Airbus H125", "type": "Helicopter"}
# ADD THESE 3 LINES:
app.config['BOEING_CONFIG'] = BOEING_CONFIG
app.config['CESSNA_CONFIG'] = CESSNA_CONFIG
app.config['AIRBUS_CONFIG'] = AIRBUS_CONFIG

