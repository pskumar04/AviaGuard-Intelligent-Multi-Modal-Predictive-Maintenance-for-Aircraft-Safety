# Import models AFTER db is initialized
from website.models import User, PredictionResult

@login_manager.user_loader
def load_user(user_id):
    """Load user by ID"""
    return User.query.get(int(user_id))

@app.context_processor
def inject_now():
    """Inject current datetime into templates"""
    return {'now': datetime.utcnow()}

@app.errorhandler(404)
def page_not_found(e):
    """404 error handler"""
    return render_template('404.html'), 404

@app.errorhandler(500)
def internal_server_error(e):
    """500 error handler"""
    return render_template('500.html'), 500

if __name__ == '__main__':
    # Create necessary directories
    os.makedirs('website/static/images', exist_ok=True)
    os.makedirs('website/static/css', exist_ok=True)
    os.makedirs('website/static/js', exist_ok=True)
    os.makedirs('logs', exist_ok=True)
    os.makedirs('data', exist_ok=True)
    
    # Create database tables
    with app.app_context():
        db.create_all()
        print("✅ Database tables created")
    
    # Import routes INSIDE the app context and BEFORE running
    with app.app_context():
        from website.routes import *
        print("✅ Routes loaded successfully")
    
    print("\n" + "="*60)
    print("✅ AIRCRAFT PREDICTIVE MAINTENANCE SYSTEM")
    print("="*60)
    print("🚀 Server starting...")
    print("📱 Open: http://localhost:5000")
    print("="*60 + "\n")
    
    # Run the app
    with app.app_context():
        app.run(debug=True, host='127.0.0.1', port=5000)